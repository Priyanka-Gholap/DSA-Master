// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(uuid())
  fullName       String
  email          String           @unique
  password       String
  avatar         String?  // Name or initials placeholder
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  progress       UserProgress[]
  lessonProgress LessonProgress[]
  problemStatus  UserProblem[]
  savedCodes     Code[]
  submissions    Submission[]
  notes          Note[]
  revisions      Revision[]
  bookmarks      Bookmark[]
  xpProfile      UserXP?
  goals          Goal[]
  activities     Activity[]
  achievements   UserAchievement[]
  visualizerPreferences VisualizerPreference?
  favoriteVisualizers   FavoriteVisualizer[]
}

model Topic {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  difficulty    String   // "Beginner" | "Intermediate" | "Advanced"
  estimatedTime String   // e.g. "45 mins"
  category      String   // e.g. "Basics" | "Data Structures" | "Algorithms"
  order         Int      @unique
  content       Json     // Rich topic details: objectives, keyConcepts, complexity operations, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  progress      UserProgress[]
  lesson        Lesson?
  problems      Problem[]
  notes         Note[]
  revisions     Revision[]
}

model UserProgress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progress    Int      @default(0) // 0 to 100
  completed   Boolean  @default(false)
  lastVisited DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, topicId])
}

model Lesson {
  id            String           @id @default(uuid())
  topicId       String           @unique
  topic         Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title         String
  introduction  String
  objectives    Json             // String[]
  prerequisites Json             // String[]
  theory        Json             // Array of objects: { type: 'heading'|'paragraph'|'tip'|'warning', text: string, level?: number }
  visualization Json             // Placeholder visual representation details
  syntax        Json             // Array of: { title: string, code: string, language: string }
  dryRun        Json             // Steps detailing array/pointer shifts
  complexity    Json             // Array of: { operation: string, best: string, average: string, worst: string, space: string }
  mistakes      Json             // Array of: { title: string, description: string }
  interviewTips Json             // Questions, most asked topics, company tips
  applications  Json             // Array of: { title: string, description: string }
  summary       Json             // Key takeaways list and next topic pointer
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  progress      LessonProgress[]
}

model LessonProgress {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  readingProgress Int      @default(0) // 0 to 100
  completed       Boolean  @default(false)
  lastReadSection String?  // name of last section read
  updatedAt       DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Problem {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  topicId       String
  topic         Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  difficulty    String        // "Easy" | "Medium" | "Hard"
  statement     String        @db.Text
  constraints   String        @db.Text
  inputFormat   String        @db.Text
  outputFormat  String        @db.Text
  sampleInput   String        @db.Text
  sampleOutput  String        @db.Text
  explanation   String        @db.Text
  estimatedTime String        // e.g. "20 mins"
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  userAttempts  UserProblem[]
  savedCodes    Code[]
  submissions   Submission[]
  notes         Note[]
  revisions     Revision[]
}

model UserProblem {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId    String
  problem      Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status       String    @default("NOT_STARTED") // "NOT_STARTED" | "ATTEMPTED" | "SOLVED"
  bookmarked   Boolean   @default(false)
  lastVisited  DateTime  @default(now())
  solvedAt     DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([userId, problemId])
}

model Code {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language   String   @default("java")
  sourceCode String   @db.Text
  updatedAt  DateTime @updatedAt

  @@unique([userId, problemId])
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  sourceCode  String   @db.Text
  language    String   @default("java")
  status      String   // "ACCEPTED" | "WRONG_ANSWER" | "COMPILATION_ERROR" | "RUNTIME_ERROR"
  runtime     Int?     // in ms
  memory      Int?     // in KB
  submittedAt DateTime @default(now())

  @@index([userId])
}

model Note {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId    String?
  topic      Topic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  problemId  String?
  problem    Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  pinned     Boolean  @default(false)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Revision {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId       String?
  topic         Topic?    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  problemId     String?
  problem       Problem?  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  scheduledDate DateTime
  completed     Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model Bookmark {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType String   // "TOPIC" | "PROBLEM" | "LESSON" | "NOTE"
  contentId   String   // Id of the targeted resource
  category    String   @default("Important") // "Interview", "Revision", "Important", "Favourite", "Difficult"
  collection  String?  // Custom collection folder title
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, contentType, contentId, category])
}

model Achievement {
  id               String            @id @default(uuid())
  title            String            @unique
  description      String
  icon             String
  xpReward         Int               @default(100)
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model Goal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  target    Int
  progress  Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Activity {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityType String   // "LESSON_COMPLETED" | "PROBLEM_SOLVED" | "REVISION_COMPLETED" | "GOAL_COMPLETED"
  description  String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model UserXP {
  id      String @id @default(uuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXP Int    @default(0)
  level   Int    @default(1)
}

model VisualizerPreference {
  id             String @id @default(uuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  animationSpeed Int    @default(500)
  preferredTheme String @default("dark")
  lastVisualizer String @default("sorting")
}

model FavoriteVisualizer {
  id             String @id @default(uuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  visualizerName String

  @@unique([userId, visualizerName])
}
